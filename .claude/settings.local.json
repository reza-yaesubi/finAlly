{
  "permissions": {
    "allow": [
      "WebFetch(domain:polygon.io)",
      "WebFetch(domain:massive.com)",
      "WebSearch",
      "Bash(uv run *)",
      "Bash(git commit -m ' *)",
      "Bash(git push *)",
      "Bash(npm run *)",
      "Bash(npx playwright *)",
      "Bash(docker stop *)",
      "Bash(docker rm *)",
      "Bash(docker run *)",
      "Bash(curl -s http://localhost:8080/api/health)",
      "Bash(curl *)",
      "Bash(docker exec finally-e2e *)",
      "Bash(python3 *)",
      "Bash(docker build *)",
      "Bash(docker volume *)",
      "Bash(grep -n static __TRACKED_VAR__/backend/app.py)"
    ]
  },
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true
  }
}
